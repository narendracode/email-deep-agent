# Copy this file to .env for local development
# cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=emailagent
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/emailagent

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Gmail OAuth2 ──────────────────────────────────────────────────────────────
# Path to your downloaded credentials.json from Google Cloud Console
GMAIL_CREDENTIALS_JSON=credentials.json
# Path where the OAuth2 token will be persisted after first auth
GMAIL_TOKEN_JSON=token.json
# How many hours of email history to fetch per run
GMAIL_FETCH_HOURS=24
# Max number of emails to process per run
GMAIL_MAX_RESULTS=100

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
